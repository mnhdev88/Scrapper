# Copy this file to ".env" and paste your keys below.
# The Google key must have BOTH APIs enabled in Google Cloud:
#   1. Places API (New)
#   2. PageSpeed Insights API
GOOGLE_API_KEY=paste-your-google-key-here

# OPTIONAL — employee count + revenue enrichment. Set ONE of these.
# Vibe / Explorium (preferred). Returns employee/revenue RANGES by domain.
# Costs ~1 credit per enriched business.
EXPLORIUM_API_KEY=

# Apollo (alternative). Needs a paid Apollo plan with API access.
# Get it at https://app.apollo.io -> Settings > Integrations > API.
APOLLO_API_KEY=
